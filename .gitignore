# ============================================================================
# .gitignore — files and directories that git should never track
# ============================================================================


# Python build and runtime artifacts
# compiled bytecode, regenerated on every run
__pycache__/
# .pyc, .pyo, .pyd — same idea
*.py[cod]
# Jython artifacts (rare)
*$py.class
# package metadata generated by `pip install -e .`
*.egg-info/
# output of `python -m build`
build/
# distribution archives
dist/


# Test and coverage artifacts
.pytest_cache/
.coverage
.coverage.*
htmlcov/


# Virtual environments — NEVER commit these
# .venv/ can be hundreds of MB of installed libraries.
.venv/
venv/
env/


# IDE / editor config
.vscode/
.idea/
*.swp


# OS-level junk
.DS_Store
Thumbs.db


# Terraform
infra/.terraform/
infra/*.tfstate
infra/*.tfstate.backup
infra/*.tfplan
infra/terraform.tfvars
infra/*.auto.tfvars
infra/.terraform.lock.hcl


# Secrets — defence in depth, NEVER commit credentials
.aws/
*.pem
*.key
credentials.csv
.env


# Local test data — don't commit huge generated files
tests/data/large_*.jsonl