# ============================================================================
# .gitignore — files and directories that git should never track
# ============================================================================


# ----------------------------------------------------------------------------
# Python build and runtime artifacts
# ----------------------------------------------------------------------------
__pycache__/                # compiled bytecode, regenerated on every run
*.py[cod]                   # .pyc, .pyo, .pyd — same idea
*$py.class                  # Jython artifacts (rare, harmless to keep here)
*.egg-info/                 # package metadata generated by `pip install -e .`
build/                      # output of `python -m build`
dist/                       # distribution archives, ditto


# ----------------------------------------------------------------------------
# Test and coverage artifacts
# ----------------------------------------------------------------------------
.pytest_cache/              # pytest's cache between runs
.coverage                   # coverage data file
.coverage.*                 # coverage data fragments
htmlcov/                    # HTML coverage reports


# ----------------------------------------------------------------------------
# Virtual environments — NEVER commit these
# ----------------------------------------------------------------------------
# .venv/ can be hundreds of MB of installed libraries. They're recreated by
# anyone with `python -m venv .venv && pip install -e ".[dev]"`.
.venv/
venv/
env/


# ----------------------------------------------------------------------------
# IDE / editor config — personal preferences, not project config
# ----------------------------------------------------------------------------
.vscode/
.idea/                      # JetBrains IDEs (PyCharm, IntelliJ)
*.swp                       # vim swap files


# ----------------------------------------------------------------------------
# OS-level junk
# ----------------------------------------------------------------------------
.DS_Store                   # macOS Finder metadata
Thumbs.db                   # Windows Explorer metadata


infra/.terraform/
infra/*.tfstate
infra/*.tfstate.backup
infra/*.tfplan              # plan output, can contain sensitive diffs
infra/terraform.tfvars      # local variable overrides
infra/*.auto.tfvars

.aws/                       # AWS CLI config directory
*.pem                       # private keys
*.key                       # other private key formats
credentials.csv             # the file AWS gives you when you create access keys
.env                        # common convention for local-only env vars


# ----------------------------------------------------------------------------
# Local test data — don't commit huge generated files
# ----------------------------------------------------------------------------
# Our streaming test generates a ~500 MB file to prove memory stays bounded.
# We don't want that in git.
tests/data/large_*.jsonl